NODE_ENV=development
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=false
DATABASE_URL=postgres://app:app@localhost:5432/app
REDIS_URL=valkey://localhost:6379
CACHE_MODE=memory
LOG_LEVEL=info
BODY_LIMIT_BYTES=1048576
HTTP_TIMEOUT_MS=8000

SESSION_TTL_SECONDS=604800
PASSWORD_MIN_LENGTH=10
PASSWORD_MAX_LENGTH=128
PASSWORD_HASH_ALGORITHM=argon2id
PASSWORD_BCRYPT_COST=10
PASSWORD_ARGON_MEMORY_COST=65536
PASSWORD_ARGON_TIME_COST=2

AUTH_RATE_LIMIT_WINDOW_SEC=60
AUTH_RATE_LIMIT_MAX=20
GLOBAL_RATE_LIMIT_WINDOW_SEC=60
GLOBAL_RATE_LIMIT_MAX=300

READINESS_CHECK_CACHE=false
