{
  "name": "api-bun-express",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "start:express": "APP_FRAMEWORK=express bun src/index.ts",
    "start:elysia": "APP_FRAMEWORK=elysia bun src/index.ts",
    "migrate": "bun src/migrations/migrate.ts",
    "migrate:smoke": "bun src/migrations/migrate.ts",
    "test": "NODE_ENV=test DB_DRIVER=sqlite bun test --preload ./test/setup.ts",
    "test:unit": "NODE_ENV=test DB_DRIVER=sqlite bun test test/*.unit.test.ts --preload ./test/setup.ts",
    "test:integration": "NODE_ENV=test DB_DRIVER=sqlite bun test test/*.integration.test.ts --preload ./test/setup.ts",
    "test:e2e": "NODE_ENV=test DB_DRIVER=sqlite bun test test/*.e2e.test.ts --preload ./test/setup.ts",
    "test:contract": "NODE_ENV=test DB_DRIVER=sqlite bun test test/openapi.contract.test.ts --preload ./test/setup.ts",
    "test:coverage": "NODE_ENV=test DB_DRIVER=sqlite bun test --coverage --preload ./test/setup.ts",
    "test:coverage:gate": "NODE_ENV=test DB_DRIVER=sqlite bun test --coverage --coverage-reporter lcov --preload ./test/setup.ts && bun run scripts/check-coverage.ts",
    "security:audit": "bun audit",
    "typecheck": "bunx tsc --noEmit",
    "ci:check": "bun run security:audit && bun run typecheck && bun run test:unit && bun run test:integration && bun run test:e2e && bun run test:contract && bun run test:coverage:gate"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "typescript": "^5"
  },
  "dependencies": {
    "elysia": "^1.4.27",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
