{
  "name": "api-bun-express",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "start:express": "APP_FRAMEWORK=express bun src/index.ts",
    "start:elysia": "APP_FRAMEWORK=elysia bun src/index.ts",
    "migrate": "bun src/migrations/migrate.ts",
    "migrate:smoke": "bun src/migrations/migrate.ts",
    "test": "bun test",
    "test:contract": "bun test test/openapi.contract.test.ts",
    "test:coverage": "bun test --coverage",
    "bench:express": "BENCH_PORT=3101 bun bench/express.server.ts",
    "bench:elysia": "BENCH_PORT=3102 bun bench/elysia.server.ts",
    "bench:elysia:real": "BENCH_PORT=3301 BENCH_HOST=0.0.0.0 bun bench/elysia.real.server.ts",
    "bench:run": "bash bench/run-benchmark.sh",
    "bench:real": "bash bench/run-real-api-benchmark.sh",
    "typecheck": "bunx tsc --noEmit",
    "ci:check": "bun run typecheck && bun run test:coverage"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "autocannon": "^8.0.0",
    "typescript": "^5"
  },
  "dependencies": {
    "elysia": "^1.4.27",
    "express": "^5.2.1",
    "zod": "^4.3.6"
  }
}
